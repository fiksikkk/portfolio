{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": [
      "vite/client"
    ],
    "paths": {
      "app/*": [
        "./src/app/*"
      ],
      "pages/*": [
        "./src/pages/*"
      ],
      "widgets/*": [
        "./src/widgets/*"
      ],
      "features/*": [
        "./src/features/*"
      ],
      "entities/*": [
        "./src/entities/*"
      ],
      "shared/*": [
        "./src/shared/*"
      ],
      "src/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src",
    "index.tsx",
    "App.tsx"
  ]
}
